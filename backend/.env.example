# ── 数据库 ──────────────────────────────────────────────────────────────────
# 开发用 SQLite（无需安装），生产环境换 MySQL
DATABASE_URL=sqlite:///./ivr_system.db
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/ivr_system

# ── 云通信平台 ───────────────────────────────────────────────────────────────
# 选择平台：aliyun（生产）/ twilio / mock（本地测试，无需账号）
CALL_PLATFORM=aliyun

# 公网回调地址（Twilio/阿里云 需要能访问到你的服务器）
# 本地开发：用 ngrok 暴露 → ngrok http 8000 → 复制 https://xxxx.ngrok-free.app
PUBLIC_URL=https://your-domain-or-ngrok-url

# ── Twilio 配置（注册 twilio.com 获取，个人账号 $15 免费额度）──────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_CALLER_NUMBER=+1xxxxxxxxxx    # Twilio 购买的号码（需支持拨打中国）

# ── 阿里云通信配置（企业账号 + 语音服务资质，暂时留空）─────────────────────
ALIYUN_ACCESS_KEY=
ALIYUN_ACCESS_SECRET=
ALIYUN_CALLER_NUMBER=
ALIYUN_VOICE_CODE_OPENING=          # 上传语音文件后获得的 VoiceCode

# ── 人工客服转接号码 ─────────────────────────────────────────────────────────
# 用户按 1-1 时转接到此号码（Twilio 测试时填真实手机号，含国家码如 +8613800138000）
AGENT_PHONE_NUMBER=+86xxxxxxxxxx

# ── 语音文件目录（阿里云方案使用，Twilio 用 TTS 无需语音文件）──────────────
VOICE_DIR=./voices
